<div class="hero">
    <h1>All Your Web Tools in One Place</h1>
    <p>Professional grade PDF, Image, and Audio tools. Free, fast, and secure.</p>

    <div class="search-wrapper">
        <input type="text" id="tool-search" placeholder="🔍  Search for a tool..." autocomplete="off">
    </div>
</div>

<div class="tools-grid" id="tools-grid">
    <a href="/compressor" class="tool-card">
        <span class="tool-icon">📉</span>
        <span class="tool-title">Image Compressor</span>
        <span class="tool-desc">Reduce image size without losing quality.</span>
    </a>
    <a href="/images-to-pdf" class="tool-card">
        <span class="tool-icon">📑</span>
        <span class="tool-title">Images to PDF</span>
        <span class="tool-desc">Convert multiple images into a single PDF file.</span>
    </a>
    <a href="/pdf-to-images" class="tool-card">
        <span class="tool-icon">🖼️</span>
        <span class="tool-title">PDF to Images</span>
        <span class="tool-desc">Extract all pages from a PDF as images.</span>
    </a>

    <a href="/resizer" class="tool-card">
        <span class="tool-icon">📐</span>
        <span class="tool-title">Image Resizer</span>
        <span class="tool-desc">Resize images to exact pixel dimensions.</span>
    </a>
    <a href="/qrcode" class="tool-card">
        <span class="tool-icon">🔳</span>
        <span class="tool-title">QR Code Generator</span>
        <span class="tool-desc">Generate instant QR codes for any text or link.</span>
    </a>
    <a href="/tts" class="tool-card">
        <span class="tool-icon">🔊</span>
        <span class="tool-title">Text to Speech</span>
        <span class="tool-desc">Convert text into natural sounding audio.</span>
    </a>
    <a href="/frequency" class="tool-card">
        <span class="tool-icon">〰️</span>
        <span class="tool-title">Frequency Generator</span>
        <span class="tool-desc">Generate pure audio tones and frequencies.</span>
    </a>
    <a href="/frequency-detector" class="tool-card">
        <span class="tool-icon">🎙️</span>
        <span class="tool-title">Frequency Detector</span>
        <span class="tool-desc">Detect the pitch and frequency of audio in real-time.</span>
    </a>
    <a href="/case-converter" class="tool-card">
        <span class="tool-icon">Aa</span>
        <span class="tool-title">Case Converter</span>
        <span class="tool-desc">Easily switch between upper, lower, and title case.</span>
    </a>
    <a href="https://webtigo-premium.vercel.app/" target="_blank" class="tool-card"
        style="border-color: var(--premium);">
        <span class="tool-icon">👑</span>
        <span class="tool-title" style="color: var(--premium);">Premium Tools</span>
        <span class="tool-desc">Unlock exclusive advanced features.</span>
    </a>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('tool-search');
        const toolCards = document.querySelectorAll('.tool-card');
        const grid = document.getElementById('tools-grid');

        searchInput.addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase().trim();
            let hasVisible = false;

            toolCards.forEach(card => {
                const title = card.querySelector('.tool-title').innerText.toLowerCase();
                const desc = card.querySelector('.tool-desc').innerText.toLowerCase();

                // Allow searching by keywords not explicitly in text
                const keywords = card.getAttribute('href').replace('/', '').replace('-', ' ');

                if (title.includes(term) || desc.includes(term) || keywords.includes(term)) {
                    card.style.display = 'flex';
                    // Re-trigger animation if hidden previously
                    if (card.style.opacity === '0') {
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0)';
                    }
                    hasVisible = true;
                } else {
                    card.style.display = 'none';
                }
            });

            // Optional: Show "No results" message could be added here
        });
    });
</script>
<div class="glass-card" style="max-width: 600px; margin: 0 auto;">
    <h1 style="margin-bottom: 2rem; text-align: center;">QR Code Generator</h1>
    <p style="text-align: center; color: rgba(255, 255, 255, 0.7); margin-bottom: 2rem; font-size: 1.05rem;">
        Create high-quality QR codes for URLs, text, and emails for <strong>free</strong>. Download instantly with no
        expiration.
    </p>

    <div class="form-group">
        <label>Enter URL or Text</label>
        <input type="text" id="qr-text" placeholder="https://example.com">
    </div>

    <button class="primary-btn" onclick="generateQR()">Generate QR</button>

    <div id="result" class="result-area" style="display: none;">
        <img id="qr-img" src="" alt="QR Code" style="max-width: 100%; border-radius: 8px; margin-bottom: 1rem;">
        <br>
        <a id="download-link" href="#" class="primary-btn"
            style="text-decoration: none; display: inline-block;">Download PNG</a>
    </div>
</div>

<script>
    async function generateQR() {
        const text = document.getElementById('qr-text').value;
        const resultDiv = document.getElementById('result');

        if (!text) return alert('Enter text');

        const formData = new FormData();
        formData.append('data', text);

        try {
            const res = await fetch('/api/generate-qr', { method: 'POST', body: formData });
            if (!res.ok) throw new Error('Failed');

            const blob = await res.blob();
            const url = URL.createObjectURL(blob);

            const img = document.getElementById('qr-img');
            img.src = url;

            const link = document.getElementById('download-link');
            link.href = url;
            link.download = `qrcode-${Date.now()}.png`;

            resultDiv.style.display = 'block';
        } catch (e) {
            alert(e.message);
        }
    }

    window.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        if (params.has('text')) {
            document.getElementById('qr-text').value = decodeURIComponent(params.get('text'));
        }
        if (params.get('auto') === 'true' && params.has('text')) {
            setTimeout(generateQR, 300);
        }
    });

</script>

<div class="glass-card"
    style="margin-top: 3rem; padding: 2rem; position: relative; text-align: center; max-width: 800px; margin-left: auto; margin-right: auto;">
    <h2
        style="color: var(--primary); margin-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 0.5rem;">
        The Magic Square</h2>
    <p style="color: rgba(255,255,255,0.8); line-height: 1.6; margin-bottom: 1.5rem; text-align: left;">
        Instead of forcing someone to type out a massive, complicated web address, a QR code lets them simply point
        their phone camera at the screen and instantly teleport to exactly where you want them to go. Did you know you
        can also use QR codes for hidden text messages instead of URLs?
    </p>
    <a href="/blog/qrcode" class="secondary-btn"
        style="background: transparent; color: var(--primary); border: 1px solid var(--primary); text-decoration: none; display: inline-block; padding: 0.75rem 1.5rem;">
        Read Full Guide on our Blog
    </a>
</div>
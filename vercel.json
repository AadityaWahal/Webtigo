{
    "version": 2,
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/index.js"
        }
    ],
    "functions": {
        "api/index.js": {
            "includeFiles": "views/**,public/**,node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs",
            "maxDuration": 60
        }
    }
}